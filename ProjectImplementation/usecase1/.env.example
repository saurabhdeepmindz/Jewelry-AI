# ─────────────────────────────────────────────────────────────────────────────
# Jewelry AI — Environment Variables
# Copy this file to .env and fill in real values. NEVER commit .env to git.
# ─────────────────────────────────────────────────────────────────────────────

# ── Application ───────────────────────────────────────────────────────────────
APP_ENV=development          # development | staging | production | testing
APP_VERSION=1.0.0
LOG_LEVEL=INFO               # DEBUG | INFO | WARNING | ERROR | CRITICAL
SECRET_KEY=                  # REQUIRED — min 32 chars, random string

# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/jewelry_ai
TEST_DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/jewelry_ai_test

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ── OpenAI ────────────────────────────────────────────────────────────────────
OPENAI_API_KEY=              # REQUIRED — sk-...
ANTHROPIC_API_KEY=           # Optional — fallback LLM

# ── Enrichment APIs ───────────────────────────────────────────────────────────
APOLLO_API_KEY=              # REQUIRED — contact enrichment
HUNTER_API_KEY=              # REQUIRED — email verification fallback
PROXYCURL_API_KEY=           # Optional — LinkedIn profile enrichment (Phase 3+)

# ── Email Delivery ────────────────────────────────────────────────────────────
SENDGRID_API_KEY=            # REQUIRED — transactional email
SENDGRID_FROM_EMAIL=         # REQUIRED — e.g. outreach@shivamjewels.com
SENDGRID_WEBHOOK_SECRET=     # Optional — for webhook signature verification

# ── WhatsApp (Phase 3+) ───────────────────────────────────────────────────────
TWILIO_ACCOUNT_SID=          # Optional
TWILIO_AUTH_TOKEN=           # Optional
TWILIO_WHATSAPP_FROM=        # Optional — e.g. whatsapp:+14155238886

# ── n8n Workflow Automation ───────────────────────────────────────────────────
N8N_WEBHOOK_URL=             # Optional — e.g. http://localhost:5678/webhook/lead-sequence

# ── MLflow ────────────────────────────────────────────────────────────────────
MLFLOW_TRACKING_URI=http://localhost:5000

# ── Grafana ───────────────────────────────────────────────────────────────────
GF_SECURITY_ADMIN_PASSWORD=  # Grafana admin password — change from default 'admin'

# ── Feature Flags ─────────────────────────────────────────────────────────────
HUMAN_REVIEW_REQUIRED=true          # Master gate: require manager approval before sending
MAX_BATCH_SIZE=500                  # Max leads per CSV upload
ENRICHMENT_CACHE_TTL_DAYS=7        # Days to cache enrichment results in Redis
INVENTORY_MATCH_MIN_CARAT=0.50     # Minimum carat weight for a valid inventory match
LEAD_SCORE_HIGH_THRESHOLD=70.0     # Score >= this → HOT tier
LEAD_SCORE_LOW_THRESHOLD=40.0      # Score < this → COLD tier

# ── Rate Limiting ─────────────────────────────────────────────────────────────
RATE_LIMIT_REP=100/minute           # Requests per minute for rep role
RATE_LIMIT_MANAGER=300/minute      # Requests per minute for manager role
