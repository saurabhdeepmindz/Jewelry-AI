# Enforce LF line endings for all text files (Windows + Linux/Mac compatibility)
* text=auto eol=lf

# Explicit LF for source files
*.py    text eol=lf
*.md    text eol=lf
*.yml   text eol=lf
*.yaml  text eol=lf
*.toml  text eol=lf
*.sh    text eol=lf
*.json  text eol=lf
*.csv   text eol=lf
*.txt   text eol=lf
*.ini   text eol=lf
*.cfg   text eol=lf
*.sql   text eol=lf
*.html  text eol=lf
*.css   text eol=lf
*.js    text eol=lf

# Windows scripts keep CRLF
*.bat   text eol=crlf
*.ps1   text eol=crlf
*.cmd   text eol=crlf

# Binary files — no line ending conversion
*.pem    binary
*.key    binary
*.pdf    binary
*.png    binary
*.jpg    binary
*.jpeg   binary
*.gif    binary
*.ico    binary
*.zip    binary
*.tar.gz binary
*.pkl    binary
*.joblib binary
